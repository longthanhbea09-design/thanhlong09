# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 48
JWT_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_48"

# ─── Admin credentials (used by prisma/seed.ts to create the first admin) ─────
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="CHANGE_ME_strong_password_min_12_chars"

# ─── Public site info ─────────────────────────────────────────────────────────
NEXT_PUBLIC_ZALO="0900000000"
NEXT_PUBLIC_SHOP_NAME="YourShopName"
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# ─── Payment provider: mock | payos | sepay ───────────────────────────────────
PAYMENT_PROVIDER="mock"

# PayOS (https://payos.vn) — leave blank if not using
PAYOS_CLIENT_ID=""
PAYOS_API_KEY=""
PAYOS_CHECKSUM_KEY=""

# SePay (https://sepay.vn) — leave blank if not using
# 1. Đăng ký tại https://sepay.vn → Merchant → Webhook
# 2. Điền endpoint: https://yourdomain.com/api/webhooks/sepay
# 3. Copy API Key từ SePay dashboard vào đây
# 4. SePay nhận giao dịch ngân hàng và gửi webhook khi có chuyển khoản
SEPAY_API_KEY=""

# MoMo — leave blank if not using
MOMO_PARTNER_CODE=""
MOMO_ACCESS_KEY=""
MOMO_SECRET_KEY=""

# VNPay — leave blank if not using
VNPAY_TMN_CODE=""
VNPAY_HASH_SECRET=""

# ─── Email / SMTP (for delivery email to customers) ──────────────────────────
# Leave blank to disable email sending
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
