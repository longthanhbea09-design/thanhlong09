# ─── DATABASE (MongoDB Atlas) ──────────────────────────────────────────────────
# LỚP 1 — Database thật (production). KHÔNG thêm NEXT_PUBLIC_ prefix.
# User MongoDB phải có quyền tối thiểu: readWrite on "thanhlongshop" only.
# Tạo tại: cloud.mongodb.com → Database Access → Add New Database User
# Chọn Built-in Role: "Read and write to any database" → scoped to "thanhlongshop"
DATABASE_URL="mongodb+srv://user-prod:StrongPassword@cluster0.xxxx.mongodb.net/thanhlongshop?retryWrites=true&w=majority&appName=Cluster0"

# LỚP 2 — Database decoy/honeypot (tùy chọn).
# Dùng user khác, database riêng "thanhlongshop_decoy".
# Chứa dữ liệu giả để phát hiện attacker.
# Nếu để trống, tính năng decoy logging bị tắt (không ảnh hưởng khách thật).
DECOY_DATABASE_URL="mongodb+srv://user-decoy:AnotherPassword@cluster0.xxxx.mongodb.net/thanhlongshop_decoy?retryWrites=true&w=majority&appName=Cluster0"

# ─── AUTH ─────────────────────────────────────────────────────────────────────
# BẮT BUỘC — tối thiểu 32 ký tự. Không được để trống hay dùng giá trị mặc định.
# Tạo bằng: openssl rand -base64 48
JWT_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_48_minimum_32_chars"

# ─── ADMIN CREDENTIALS (chỉ dùng cho seed lần đầu) ───────────────────────────
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="CHANGE_ME_strong_password_min_12_chars"

# ─── PUBLIC SITE INFO ─────────────────────────────────────────────────────────
NEXT_PUBLIC_ZALO="0900000000"
NEXT_PUBLIC_SHOP_NAME="YourShopName"
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# ─── ADMIN SEARCH GATE ────────────────────────────────────────────────────────
# Câu lệnh ẩn trong ô tìm kiếm sản phẩm. Nhấn Enter đúng lệnh → redirect /admin/login.
# KHÔNG được thêm NEXT_PUBLIC_ prefix. Check hoàn toàn server-side.
# Đặt chuỗi dài, ngẫu nhiên, khó đoán. Không dùng tên/ngày sinh.
ADMIN_SEARCH_SECRET="CHANGE_ME_random_secret_hard_to_guess"

# ─── SECURITY LOGGING ─────────────────────────────────────────────────────────
# Bật để ghi SecurityLog vào MongoDB. "false" = chỉ log console.
SECURITY_LOG_ENABLED="true"

# ─── PAYMENT PROVIDER: mock | payos | sepay | momo | vnpay ───────────────────
PAYMENT_PROVIDER="mock"

# PayOS (https://payos.vn) — để trống nếu không dùng
PAYOS_CLIENT_ID=""
PAYOS_API_KEY=""
PAYOS_CHECKSUM_KEY=""

# SePay (https://sepay.vn) — để trống nếu không dùng
SEPAY_API_KEY=""

# MoMo (https://business.momo.vn) — để trống nếu không dùng
# KHÔNG thêm NEXT_PUBLIC_ — secret key không được lộ ra client
MOMO_PARTNER_CODE=""
MOMO_ACCESS_KEY=""
MOMO_SECRET_KEY=""
MOMO_ENDPOINT="https://payment.momo.vn"
MOMO_IPN_URL="https://yourdomain.com/api/payments/momo/ipn"
MOMO_RETURN_URL="https://yourdomain.com/checkout"

# VNPay (https://vnpayment.vn) — để trống nếu không dùng
# KHÔNG thêm NEXT_PUBLIC_ — hash secret không được lộ ra client
VNPAY_TMN_CODE=""
VNPAY_HASH_SECRET=""
VNPAY_PAYMENT_URL="https://pay.vnpay.vn/vpcpay.html"
VNPAY_RETURN_URL="https://yourdomain.com/checkout"
VNPAY_IPN_URL="https://yourdomain.com/api/payments/vnpay/ipn"

# ─── ENCRYPTION KEY (mã hóa password tài khoản trong DB) ─────────────────────
# Tạo: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Phải là 64 ký tự hex (32 bytes) hoặc 44 ký tự base64 (32 bytes)
# KHÔNG thêm NEXT_PUBLIC_ — KHÔNG commit key này vào git
ENCRYPTION_KEY="CHANGE_ME_64_hex_chars_or_44_base64_chars"

# ─── CLOUDINARY (image uploads) ──────────────────────────────────────────────
# Tạo tại: cloudinary.com → Settings → API Keys
# KHÔNG thêm NEXT_PUBLIC_ prefix cho API_SECRET
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── EMAIL / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# ─── WEBAUTHN / PASSKEY ───────────────────────────────────────────────────────
WEBAUTHN_RP_ID="yourdomain.com"
WEBAUTHN_ORIGIN="https://yourdomain.com"
